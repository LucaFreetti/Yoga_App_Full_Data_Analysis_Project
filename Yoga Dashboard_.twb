      <aliases enabled='yes' />
      <column caption='Multi paese' datatype='string' name='[Calculation_1053883222405120]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNTD([country]) &gt; 1 THEN &quot;Multi-paese&quot; ELSE &quot;Single paese&quot; END' />
      </column>
      <column caption='Numero paesi per utente' datatype='boolean' name='[Calculation_1053883223568385]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [user_id] : COUNTD([country])} &gt;= 2' />
      </column>
      <column caption='Media utenti per classe' datatype='real' name='[Calculation_1204240636813333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([class_id]) / COUNTD([user_id])' />
      </column>
      <column caption='classi per utente' datatype='integer' name='[Calculation_1204240679772182]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([class_id])' />
      </column>
      <column caption='giorni attivi' datatype='integer' name='[Calculation_1204240680411159]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNTD([class_date]) }' />
      </column>
      <column caption='Categorie provate' datatype='integer' name='[Calculation_1204240680681496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNTD([category]) }' />
      </column>
      <column caption='livelli provati' datatype='integer' name='[Calculation_1204240680833049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNTD([level]) }' />
      </column>
      <column caption='media stelle' datatype='real' name='[Calculation_1204240681021466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([stars])' />
      </column>
      <column caption='Person&apos;s Type' datatype='string' name='[Calculation_1204240682848283]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1204308321136654] &gt;= 7 THEN &quot;Gandhi&quot;&#13;&#10;ELSEIF [Calculation_1204240680681496] &gt;= 3 AND [Calculation_1204240680833049] &gt;= 3 THEN &quot;Siddharta&quot;&#13;&#10;ELSEIF [Calculation_1204240680681496] &lt; 3 AND [Calculation_1204240680833049] &lt; 3 AND [Calculation_1204241036881956] &gt;= 3 THEN &quot;Scambista&quot;&#13;&#10;ELSEIF [Calculation_1204240693321757] &gt;= 3.2 AND [Calculation_1204308321136654] &gt;= 4 THEN &quot;Maestro Zen&quot;&#13;&#10;ELSE &quot;Equilibrista&quot;&#13;&#10;END' />
      </column>
      <column caption='user ratings' datatype='real' name='[Calculation_1204240693321757]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : AVG([stars]) }' />
      </column>
      <column caption='Lezioni per utente anno' datatype='integer' name='[Calculation_1204241008873506]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id], [anno] : COUNTD([class_id]) }' />
      </column>
      <column caption='Numero_lezioni_nuovo' datatype='string' name='[Calculation_1204241009078307]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1204241008873506] = 1 THEN &quot;Single Lesson&quot;&#13;&#10;ELSEIF [Calculation_1204241008873506] &lt; 7 THEN &quot;From 2 to 6 Lessons&quot;&#13;&#10;ELSE &quot;More than 6 Lessons&quot;&#13;&#10;END' />
      </column>
      <column caption='coach_provati' datatype='integer' name='[Calculation_1204241036881956]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNTD([coach_id]) }' />
      </column>
      <column caption='media coach cambiati' datatype='real' name='[Calculation_1204241039183909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1204308330356754] &gt; 1 THEN&#13;&#10;[Calculation_1204308330356754] / [Calculation_1204241036881956]&#13;&#10;END' />
      </column>
      <column caption='top 5 and last 5_coach' datatype='boolean' name='[Calculation_1204307941941248]' role='measure' type='nominal'>
        <calculation class='tableau' formula='INDEX() &lt;= 5 OR LAST() &lt;= 4'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='coach_colors' datatype='string' name='[Calculation_1204307945742339]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF INDEX() &lt;= 5 THEN &quot;Primi 5&quot;&#13;&#10;ELSEIF LAST() &lt;= 4 THEN &quot;Ultimi 5&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='lezioni totali per utente(countd)' datatype='integer' name='[Calculation_1204308321136654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNTD([class_id]) }' />
      </column>
      <column caption='lezioni totali (count)' datatype='integer' name='[Calculation_1204308330356754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id] : COUNT([class_id]) }' />
      </column>
